# Backend environment variables. Copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pcx
DB_USER=postgres
DB_PASS=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong random value, e.g.:  openssl rand -hex 32
JWT_SECRET=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allowed frontend origin (omit to allow all origins — dev only).
FRONTEND_ORIGIN=

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
# App secret used to verify inbound webhook signatures. If unset, inbound
# webhooks are REJECTED (fail closed). For local dev without a secret, set
# WHATSAPP_WEBHOOK_ALLOW_UNSIGNED=true to accept unsigned webhooks.
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_ALLOW_UNSIGNED=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_BASE=https://graph.facebook.com
