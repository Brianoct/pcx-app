# PCX backend environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pcx_quotes
DB_USER=postgres
DB_PASS=change_me

# --- Auth ---
# Generate a strong random value, e.g. `openssl rand -hex 32`.
# Changing this invalidates all existing sessions (everyone is logged out).
JWT_SECRET=replace_with_long_random_string

# --- Server ---
PORT=4000
# Comma-separated list of allowed frontend origins for CORS.
# Omit to allow all origins (dev only).
FRONTEND_ORIGIN=http://localhost:5173

# --- Public customer menu / share links ---
PUBLIC_APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# TTL (seconds) for public customer-menu tokens.
CUSTOMER_MENU_TOKEN_TTL=2592000

# --- AI provider (powers Asistente IA + Ventas IA) — optional ---
# Choose the provider with AI_PROVIDER: grok (default) | openai | anthropic.
# If no API key is configured for the active provider, AI features fall back to
# non-generative template/keyword summaries.
#
#   AI_PROVIDER=grok
#   AI_API_KEY=...           # generic key (overrides the provider-specific one)
#   AI_MODEL=...             # optional model override
#   AI_API_URL=...           # optional endpoint override (e.g. a proxy)
AI_PROVIDER=grok
AI_API_KEY=
AI_MODEL=
AI_API_URL=

# Provider-specific keys (used if AI_API_KEY is not set):
# Grok (xAI, OpenAI-compatible) — default provider
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-2-latest
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Ventas IA: audio + image understanding (optional) ---
# Audio (voice notes) -> text via an OpenAI-compatible transcription endpoint
# (Whisper). Anthropic/Grok cannot transcribe audio, so set an OpenAI key here
# even if your chat provider is Anthropic. If unset, voice notes stay as "[Audio]".
AI_TRANSCRIBE_API_KEY=
AI_TRANSCRIBE_MODEL=whisper-1
AI_TRANSCRIBE_URL=https://api.openai.com/v1/audio/transcriptions
# Image (catalog photos / circled products) -> text via the chat provider's
# vision model. openai (gpt-4o-mini) and anthropic (claude-3-5-sonnet) are
# vision-capable by default; for grok set a vision model (e.g. grok-2-vision).
AI_VISION_MODEL=
AI_VISION_API_KEY=

# --- AI assistant private beta ---
# Comma-separated allowlist of admin emails that can see and use the
# "Asistente IA" tab in the Admin panel. Fail-closed: if empty/unset, the
# assistant is hidden and disabled for everyone. Example:
#   AI_BETA_EMAILS=brian@pcxind.com
AI_BETA_EMAILS=

# --- WhatsApp Business (Meta Cloud API) — optional ---
# App secret used to verify inbound webhook signatures. If unset, inbound
# webhooks are REJECTED (fail closed). For local dev without a secret, set
# WHATSAPP_WEBHOOK_ALLOW_UNSIGNED=true to accept unsigned webhooks.
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_ALLOW_UNSIGNED=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_API_BASE=https://graph.facebook.com
